{
  "buildCommand": "cd focus-terminal && npm install --legacy-peer-deps && node scripts/build-config.js && npm run build",
  "outputDirectory": "focus-terminal/dist/focus-terminal/browser",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}